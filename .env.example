# ========================================
# Lite Note 环境变量配置示例
# ========================================
# 复制此文件为 .env 并根据需要修改配置值
# ========================================

# ----------------------------------------
# Cassandra 数据库配置
# ----------------------------------------

# Cassandra 连接点（多个节点用逗号分隔）
# 格式: host1:port1,host2:port2
CASSANDRA_CONTACT_POINTS=localhost:9042

# 本地数据中心名称（必须与 Cassandra 配置一致）
CASSANDRA_LOCAL_DC=datacenter1

# 是否启用 Cassandra 功能（true/false）
CASSANDRA_ENABLED=true

# Cassandra 连接超时（毫秒）
CASSANDRA_CONNECT_TIMEOUT=5000

# Cassandra 请求超时（毫秒）
CASSANDRA_REQUEST_TIMEOUT=12000

# ----------------------------------------
# 应用配置
# ----------------------------------------

# 应用端口
PORT=3000

# 环境模式（development/production）
NODE_ENV=development

# ----------------------------------------
# 数据库配置（SQLite/LowDB）
# ----------------------------------------

# 数据存储目录
DATA_DIR=./data

# SQLite 数据库文件路径
SQLITE_DB_PATH=./data/sqlite.db
# ========================================
# LiteNote 环境变量配置
# ========================================

# ----------------------------------------
# Cassandra 配置
# ----------------------------------------
# Cassandra连接点（多个用逗号分隔）
CASSANDRA_CONTACT_POINTS=localhost:9042

# 本地数据中心名称
CASSANDRA_LOCAL_DC=datacenter1

# 是否启用Cassandra（设为false可禁用分析功能）
CASSANDRA_ENABLED=true
